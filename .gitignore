# Local .terraform directories and lock file
.terraform/
.terraform.lock.hcl

# Terraform state files — never commit state or backups
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!*.tfvars.example

# Plan output files
*.tfplan
plan_output.txt

# Override files (local dev only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
